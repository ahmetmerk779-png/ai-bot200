# Minecraft Bot Configuration
BOT_USERNAME=AIBot
BOT_PASSWORD=password123
MC_SERVER=localhost
MC_PORT=25565
MC_VERSION=1.20.1
BOT_EMAIL=bot@example.com

# AI API Configuration
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
GROQ_API_KEY=your-groq-key-here

# Web Dashboard
WEB_PORT=3000
DASHBOARD_SECRET=your-secret-key

# Proxy Configuration
PROXY_TYPE=velocity
PROXY_SERVER=proxy.example.com
PROXY_PORT=25577

# Bot Behavior
AUTO_MINE=true
AUTO_FARM=true
AUTO_FISH=true
AUTO_FIGHT=true
SURVIVAL_MODE=true
MAP_EXPLORATION=true

# Logging
LOG_LEVEL=info
LOG_FILE=logs/bot.log
